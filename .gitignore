# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
hacktui-*.tar

# Keep database passwords and secrets local
.env
.env.*
!.env.example

# Local agent/session artifacts
.hermes_logs/
hermes_conversation_*.json
tmp_hacktui_mcp_probe.py

# Keep generated system and error logs local
/logs/

# Local runtime configs
config/runtime.secret.exs
config/*.local.exs

# SQLite / local databases
*.db
*.sqlite
*.sqlite3

# OS junk
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

# Direnv
.envrc

# MCP / tool experiment scripts
*.probe.py

# Test recordings
recordings/
